---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
---

<Layout title="Blog">
  <section class="blog-index">
    <header class="blog-header">
      <h1>Latest Posts</h1>
      <p class="lead">Notes, analysis, and experiments from recent projects.</p>
    </header>
    <div class="post-list">
    {posts
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
      .map((post) => (
        <a class="post-item-link" href={`/blog/${post.slug}`} aria-label={`Read post: ${post.data.title}`}>
          <article class="post-item">
            <h2>{post.data.title}</h2>
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            {post.data.description && (
              <p class="description">{post.data.description}</p>
            )}
          </article>
        </a>
      ))
    }
    </div>
  </section>
</Layout>

<style>
  .blog-index {
    padding: 2.25rem 0 1rem;
  }

  .blog-header {
    margin-bottom: 1.75rem;
  }

  .blog-header h1 {
    margin: 0;
    line-height: 1.15;
  }

  .lead {
    margin: 0.75rem 0 0;
    color: var(--color-muted);
    max-width: 42ch;
  }

  .post-list {
    margin: 0;
    display: grid;
    gap: 0.9rem;
  }

  .post-item-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .post-item-link * {
    text-decoration: none;
  }

  .post-item {
    margin-bottom: 0;
    padding: 1.15rem 1.2rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: #fff;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  }

  .post-item-link:hover .post-item {
    border-color: #d2d8e0;
    box-shadow: 0 6px 18px rgba(17, 17, 17, 0.06);
    transform: translateY(-1px);
  }

  .post-item-link:focus-visible .post-item {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(230, 57, 70, 0.2);
  }

  .post-item h2 {
    margin: 0;
    border-bottom: none;
    font-size: 1.25rem;
    line-height: 1.3;
  }

  .post-item-link:hover .post-item h2 {
    color: var(--color-accent);
  }

  .post-item time {
    display: block;
    color: var(--color-muted);
    font-size: 0.85rem;
    margin: 0.45rem 0 0.4rem;
  }

  .description {
    color: var(--color-muted);
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (max-width: 720px) {
    .blog-index {
      padding-top: 1.75rem;
    }

    .post-item {
      padding: 1rem;
    }
  }
</style>
