---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Welcome">
  <canvas id="matrix-rain"></canvas>
  <canvas id="ripple-canvas"></canvas>
  <canvas id="title-splash"></canvas>
  <div id="hero-ground"></div>
  <img id="hero-outline" src="/me4.jpg" alt="" />
  <div class="hero">
    <h1>It's Raining Information</h1>
    <p class="hero-subtitle">A disjointed collection of my notebooks.</p>
    <p class="hero-credential">M.Sc. in Data Science</p>
  </div>
</Layout>

<style>
  #matrix-rain {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: -1;
  }

  #ripple-canvas {
    position: fixed;
    left: 0;
    width: 100vw;
    height: 60px;
    pointer-events: none;
    z-index: -1;
    bottom: 0;
  }

  #title-splash {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 2;
  }

  #hero-outline {
    position: fixed;
    left: 50%;
    bottom: -2px;
    height: 244px;
    width: auto;
    max-width: 190px;
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 1;
    opacity: 0.9;
    filter: saturate(0.82) contrast(0.9) brightness(0.98) hue-rotate(6deg);
  }

  #hero-ground {
    position: fixed;
    left: 50%;
    bottom: 2px;
    width: 190px;
    height: 26px;
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(
      ellipse at center,
      rgba(0, 95, 184, 0.18) 0%,
      rgba(0, 95, 184, 0.1) 43%,
      rgba(0, 95, 184, 0) 78%
    );
  }

  .hero {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 5rem 0;
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .hero h1 {
    font-size: 2.35rem;
    margin-bottom: 0.55rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: rgba(0, 0, 0, 0.72);
  }

  .hero-subtitle {
    font-size: 1.02rem;
    color: rgba(35, 35, 35, 0.6);
    margin-bottom: 0.45rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-credential {
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(20, 20, 20, 0.43);
    margin: 0 0 2.1rem;
  }

  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }

  .cta-button {
    display: inline-block;
    padding: 0.8rem 2rem;
    background-color: var(--color-nav-bg);
    color: white;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: background-color 0.15s;
    border: 2px solid var(--color-nav-bg);
  }

  .cta-button:hover {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>

<script>
  const canvas = document.getElementById('matrix-rain') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const rippleCanvas = document.getElementById('ripple-canvas') as HTMLCanvasElement;
  const rctx = rippleCanvas.getContext('2d')!;
  const titleSplashCanvas = document.getElementById('title-splash') as HTMLCanvasElement;
  const tsctx = titleSplashCanvas.getContext('2d')!;
  const heroOutlineImg = document.getElementById('hero-outline') as HTMLImageElement | null;
  const heroTitle = document.querySelector('.hero h1') as HTMLElement | null;
  const heroSubtitle = document.querySelector('.hero-subtitle') as HTMLElement | null;
  const rootStyles = getComputedStyle(document.documentElement);
  const pageBg = rootStyles.getPropertyValue('--color-bg').trim() || '#f4f5f7';

  const rippleHeight = 60;

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    rippleCanvas.width = window.innerWidth;
    rippleCanvas.height = rippleHeight;
    titleSplashCanvas.width = window.innerWidth;
    titleSplashCanvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  const chars = 'アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン0123456789ABCDEF';
  const charArr = chars.split('');
  const fontSize = 14;
  let columns = Math.floor(canvas.width / fontSize);
  let drops: number[] = [];

  function initDrops() {
    columns = Math.floor(canvas.width / fontSize);
    drops = [];
    for (let i = 0; i < columns; i++) {
      drops[i] = Math.random() * -100;
    }
  }
  initDrops();
  window.addEventListener('resize', initDrops);

  interface Ripple {
    x: number;
    radius: number;
    maxRadius: number;
    opacity: number;
  }

  interface SplashDroplet {
    vx: number;
    vy: number;
    size: number;
    xBias: number;
  }

  interface TitleSplash {
    x: number;
    y: number;
    age: number;
    life: number;
    opacity: number;
    droplets: SplashDroplet[];
  }

  let ripples: Ripple[] = [];
  let titleSplashes: TitleSplash[] = [];

  function spawnRipple(x: number) {
    ripples.push({
      x,
      radius: 1,
      maxRadius: 20 + Math.random() * 30,
      opacity: 0.6 + Math.random() * 0.2,
    });
  }

  function spawnTitleSplash(x: number, y: number) {
    const dropletCount = 6 + Math.floor(Math.random() * 5);
    const droplets: SplashDroplet[] = [];
    for (let i = 0; i < dropletCount; i++) {
      droplets.push({
        vx: (Math.random() - 0.5) * 2.2,
        vy: -2.2 - Math.random() * 2.2,
        size: 0.8 + Math.random() * 1.5,
        xBias: (Math.random() - 0.5) * 6,
      });
    }

    titleSplashes.push({
      x,
      y,
      age: 0,
      life: 14 + Math.random() * 8,
      opacity: 0.5 + Math.random() * 0.25,
      droplets,
    });
  }

  let lastTime = 0;
  const frameInterval = 40; // ~25 fps
  const umbrellaCore = 0.78;
  const effectRgb = '0, 95, 184';

  function getUmbrellaStrength(
    x: number,
    y: number,
    zone: { cx: number; cy: number; rx: number; ry: number }
  ) {
    const nx = (x - zone.cx) / zone.rx;
    const ny = (y - zone.cy) / zone.ry;
    const dist = Math.sqrt(nx * nx + ny * ny);
    if (dist <= umbrellaCore) return 1;
    if (dist >= 1) return 0;
    const t = (1 - dist) / (1 - umbrellaCore);
    // Smoothstep for softer edge transition
    return t * t * (3 - 2 * t);
  }

  function dilateMask(mask: Uint8Array, width: number, height: number) {
    const out = new Uint8Array(mask.length);
    for (let y = 0; y < height; y++) {
      for (let x = 0; x < width; x++) {
        let on = 0;
        for (let yy = -1; yy <= 1 && !on; yy++) {
          const ny = y + yy;
          if (ny < 0 || ny >= height) continue;
          for (let xx = -1; xx <= 1; xx++) {
            const nx = x + xx;
            if (nx < 0 || nx >= width) continue;
            if (mask[ny * width + nx]) {
              on = 1;
              break;
            }
          }
        }
        out[y * width + x] = on;
      }
    }
    return out;
  }

  function erodeMask(mask: Uint8Array, width: number, height: number) {
    const out = new Uint8Array(mask.length);
    for (let y = 0; y < height; y++) {
      for (let x = 0; x < width; x++) {
        let keep = 1;
        for (let yy = -1; yy <= 1 && keep; yy++) {
          const ny = y + yy;
          if (ny < 0 || ny >= height) {
            keep = 0;
            break;
          }
          for (let xx = -1; xx <= 1; xx++) {
            const nx = x + xx;
            if (nx < 0 || nx >= width || !mask[ny * width + nx]) {
              keep = 0;
              break;
            }
          }
        }
        out[y * width + x] = keep;
      }
    }
    return out;
  }

  function keepLargestBlob(mask: Uint8Array, width: number, height: number) {
    const visited = new Uint8Array(mask.length);
    const best = new Uint8Array(mask.length);
    let bestCount = 0;

    for (let i = 0; i < mask.length; i++) {
      if (!mask[i] || visited[i]) continue;
      const queue: number[] = [i];
      const blob: number[] = [];
      visited[i] = 1;

      for (let q = 0; q < queue.length; q++) {
        const idx = queue[q];
        blob.push(idx);
        const x = idx % width;
        const y = (idx - x) / width;
        const neighbors = [
          [x - 1, y], [x + 1, y], [x, y - 1], [x, y + 1],
          [x - 1, y - 1], [x + 1, y - 1], [x - 1, y + 1], [x + 1, y + 1],
        ];
        for (let n = 0; n < neighbors.length; n++) {
          const nx = neighbors[n][0];
          const ny = neighbors[n][1];
          if (nx < 0 || nx >= width || ny < 0 || ny >= height) continue;
          const ni = ny * width + nx;
          if (mask[ni] && !visited[ni]) {
            visited[ni] = 1;
            queue.push(ni);
          }
        }
      }

      if (blob.length > bestCount) {
        best.fill(0);
        for (let b = 0; b < blob.length; b++) {
          best[blob[b]] = 1;
        }
        bestCount = blob.length;
      }
    }

    return best;
  }

  function keepSeedBlob(mask: Uint8Array, width: number, height: number, seedX: number, seedY: number) {
    const out = new Uint8Array(mask.length);
    const visited = new Uint8Array(mask.length);

    const clampX = Math.max(0, Math.min(width - 1, seedX));
    const clampY = Math.max(0, Math.min(height - 1, seedY));
    let seedIdx = clampY * width + clampX;

    if (!mask[seedIdx]) {
      let found = -1;
      for (let r = 1; r < Math.max(width, height) && found < 0; r++) {
        const x0 = Math.max(0, clampX - r);
        const x1 = Math.min(width - 1, clampX + r);
        const y0 = Math.max(0, clampY - r);
        const y1 = Math.min(height - 1, clampY + r);
        for (let y = y0; y <= y1 && found < 0; y++) {
          for (let x = x0; x <= x1; x++) {
            const idx = y * width + x;
            if (mask[idx]) {
              found = idx;
              break;
            }
          }
        }
      }
      if (found < 0) return out;
      seedIdx = found;
    }

    const queue: number[] = [seedIdx];
    visited[seedIdx] = 1;
    out[seedIdx] = 1;

    for (let q = 0; q < queue.length; q++) {
      const idx = queue[q];
      const x = idx % width;
      const y = (idx - x) / width;
      const neighbors = [
        [x - 1, y], [x + 1, y], [x, y - 1], [x, y + 1],
        [x - 1, y - 1], [x + 1, y - 1], [x - 1, y + 1], [x + 1, y + 1],
      ];
      for (let n = 0; n < neighbors.length; n++) {
        const nx = neighbors[n][0];
        const ny = neighbors[n][1];
        if (nx < 0 || nx >= width || ny < 0 || ny >= height) continue;
        const ni = ny * width + nx;
        if (mask[ni] && !visited[ni]) {
          visited[ni] = 1;
          out[ni] = 1;
          queue.push(ni);
        }
      }
    }

    return out;
  }

  function countMask(mask: Uint8Array) {
    let count = 0;
    for (let i = 0; i < mask.length; i++) {
      if (mask[i]) count++;
    }
    return count;
  }

  function detectEdge(mask: Uint8Array, width: number, height: number) {
    const edge = new Uint8Array(mask.length);
    for (let y = 0; y < height; y++) {
      for (let x = 0; x < width; x++) {
        const idx = y * width + x;
        if (!mask[idx]) continue;
        let border = 0;
        for (let yy = -1; yy <= 1 && !border; yy++) {
          const ny = y + yy;
          if (ny < 0 || ny >= height) {
            border = 1;
            break;
          }
          for (let xx = -1; xx <= 1; xx++) {
            const nx = x + xx;
            if (nx < 0 || nx >= width || !mask[ny * width + nx]) {
              border = 1;
              break;
            }
          }
        }
        if (border) edge[idx] = 1;
      }
    }
    return edge;
  }

  function initHeroImage() {
    if (!heroOutlineImg) return;
    const sourcePath = heroOutlineImg.getAttribute('src') || '/me4.jpg';
    const candidates = Array.from(new Set([sourcePath, '/me4.jpg', 'me4.jpg', './me4.jpg']));
    const tryLoadAt = (idx: number) => {
      if (idx >= candidates.length) {
        heroOutlineImg.style.display = 'none';
        return;
      }
      heroOutlineImg.onerror = () => tryLoadAt(idx + 1);
      heroOutlineImg.src = candidates[idx];
    };
    tryLoadAt(0);
  }

  function draw(timestamp: number) {
    requestAnimationFrame(draw);

    if (timestamp - lastTime < frameInterval) return;
    lastTime = timestamp;

    // The waterline: rain stops just above the ripple rings
    const waterline = canvas.height - 20;

    // Full clear each frame avoids accumulated column darkening.
    ctx.fillStyle = pageBg;
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    // Clear everything below the waterline so rain doesn't bleed through
    ctx.fillStyle = pageBg;
    ctx.fillRect(0, waterline, canvas.width, canvas.height - waterline);

    const titleRect = heroTitle?.getBoundingClientRect();
    const subtitleRect = heroSubtitle?.getBoundingClientRect();
    let umbrellaZone: { cx: number; cy: number; rx: number; ry: number } | null = null;
    if (titleRect && subtitleRect) {
      const left = Math.min(titleRect.left, subtitleRect.left) - 26;
      const right = Math.max(titleRect.right, subtitleRect.right) + 26;
      const top = titleRect.top - 18;
      const bottom = subtitleRect.bottom + 26;
      umbrellaZone = {
        cx: (left + right) * 0.5,
        cy: (top + bottom) * 0.5,
        rx: (right - left) * 0.5,
        ry: (bottom - top) * 0.5,
      };
    }
    ctx.font = `${fontSize}px "Baloo 2", sans-serif`;

    for (let i = 0; i < drops.length; i++) {
      if (drops[i] < 0) {
        drops[i] += 0.7;
        continue;
      }

      const char = charArr[Math.floor(Math.random() * charArr.length)];
      const x = i * fontSize;
      const y = drops[i] * fontSize;
      const impactX = x + fontSize * 0.5;

      // Stop drawing if past the waterline
      if (y >= waterline) {
        spawnRipple(Math.min(impactX, canvas.width));
        drops[i] = Math.random() * -30;
        continue;
      }

      if (
        titleRect &&
        impactX >= titleRect.left &&
        impactX <= titleRect.right &&
        y >= titleRect.top &&
        y <= titleRect.bottom &&
        Math.random() < 0.3
      ) {
        spawnTitleSplash(impactX, y);
      }

      // Umbrella effect over the title + subtitle block:
      // drops that reach this zone are absorbed and reset before passing below it.
      const umbrellaStrength = umbrellaZone ? getUmbrellaStrength(impactX, y, umbrellaZone) : 0;
      if (umbrellaStrength > 0.92) {
        drops[i] = Math.random() * -45;
        continue;
      }

      // Lead character
      const leadAlpha = 0.66 * (1 - umbrellaStrength * 0.9);
      const drawX = x + (Math.random() - 0.5) * 0.8;
      ctx.fillStyle = `rgba(${effectRgb}, ${leadAlpha})`;
      ctx.fillText(char, drawX, y);

      // Short-lived trail: visible in-motion, no long persistence.
      if (drops[i] > 1) {
        const baseTrailAlpha = 0.3 * (1 - umbrellaStrength * 0.85);
        const trailSteps = [1, 2, 3, 4, 5];
        for (let t = 0; t < trailSteps.length; t++) {
          const step = trailSteps[t];
          const trailChar = charArr[Math.floor(Math.random() * charArr.length)];
          const trailAlpha = baseTrailAlpha * (1 - t * 0.2);
          ctx.fillStyle = `rgba(${effectRgb}, ${trailAlpha})`;
          ctx.fillText(trailChar, drawX, y - fontSize * step);
        }
      }

      drops[i] += 0.85;
    }

    // --- Draw title splashes ---
    tsctx.clearRect(0, 0, titleSplashCanvas.width, titleSplashCanvas.height);
    for (let i = titleSplashes.length - 1; i >= 0; i--) {
      const s = titleSplashes[i];
      const progress = s.age / s.life;
      const currentOpacity = s.opacity * (1 - progress);
      const gravity = 0.18 * s.age;

      // Bright impact core
      tsctx.beginPath();
      tsctx.arc(s.x, s.y, 1.2 + progress * 1.8, 0, Math.PI * 2);
      tsctx.fillStyle = `rgba(${effectRgb}, ${currentOpacity})`;
      tsctx.fill();

      // Ballistic droplets for a stronger "splash" feel
      for (let j = 0; j < s.droplets.length; j++) {
        const d = s.droplets[j];
        const px = s.x + d.xBias + d.vx * s.age;
        const py = s.y + d.vy * s.age + gravity;
        tsctx.beginPath();
        tsctx.arc(px, py, d.size * (1 - progress * 0.35), 0, Math.PI * 2);
        tsctx.fillStyle = `rgba(${effectRgb}, ${currentOpacity * 0.95})`;
        tsctx.fill();
      }

      s.age += 1;

      if (s.age >= s.life) {
        titleSplashes.splice(i, 1);
      }
    }

    // --- Draw ripples ---
    rctx.clearRect(0, 0, rippleCanvas.width, rippleCanvas.height);

    for (let i = ripples.length - 1; i >= 0; i--) {
      const r = ripples[i];
      const progress = r.radius / r.maxRadius;
      const currentOpacity = r.opacity * (1 - progress);

      // Outer ring
      rctx.beginPath();
      rctx.ellipse(r.x, rippleCanvas.height - 5, r.radius, r.radius * 0.35, 0, 0, Math.PI * 2);
      rctx.strokeStyle = `rgba(${effectRgb}, ${currentOpacity})`;
      rctx.lineWidth = 2;
      rctx.stroke();

      // Inner ring
      if (r.radius > 5) {
        rctx.beginPath();
        rctx.ellipse(r.x, rippleCanvas.height - 5, r.radius * 0.5, r.radius * 0.18, 0, 0, Math.PI * 2);
        rctx.strokeStyle = `rgba(${effectRgb}, ${currentOpacity * 0.7})`;
        rctx.lineWidth = 1.5;
        rctx.stroke();
      }

      r.radius += 0.4;

      if (r.radius >= r.maxRadius) {
        ripples.splice(i, 1);
      }
    }
  }

  // Clear canvas to white first
  ctx.fillStyle = pageBg;
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  initHeroImage();
  requestAnimationFrame(draw);

  // Text decode animation removed — headings are now static
</script>
