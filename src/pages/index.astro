---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Welcome">
  <canvas id="matrix-rain"></canvas>
  <canvas id="ripple-canvas"></canvas>
  <canvas id="title-splash"></canvas>
  <div id="hero-ground"></div>
  <img id="hero-outline" src="/me.jpg" alt="" />
  <div class="hero">
    <h1>It's Raining Information</h1>
    <p class="hero-subtitle">A disjointed collection of my notebooks.</p>
    <p class="hero-credential">M.Sc. in Data Science</p>
  </div>
</Layout>

<style>
  #matrix-rain {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: -1;
  }

  #ripple-canvas {
    position: fixed;
    left: 0;
    width: 100vw;
    height: 60px;
    pointer-events: none;
    z-index: -1;
    bottom: 0;
  }

  #title-splash {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 2;
  }

  #hero-outline {
    position: fixed;
    left: 50%;
    bottom: -2px;
    height: 244px;
    width: auto;
    max-width: 190px;
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 1;
    opacity: 0.9;
    filter: saturate(0.82) contrast(0.9) brightness(0.98) hue-rotate(6deg);
  }

  #hero-ground {
    position: fixed;
    left: 50%;
    bottom: 2px;
    width: 190px;
    height: 26px;
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(
      ellipse at center,
      rgba(0, 95, 184, 0.18) 0%,
      rgba(0, 95, 184, 0.1) 43%,
      rgba(0, 95, 184, 0) 78%
    );
  }

  .hero {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 5rem 0;
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .hero h1 {
    font-size: 2.35rem;
    margin-bottom: 0.55rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: rgba(0, 0, 0, 0.72);
  }

  .hero-subtitle {
    font-size: 1.02rem;
    color: rgba(35, 35, 35, 0.6);
    margin-bottom: 0.45rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-credential {
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(20, 20, 20, 0.43);
    margin: 0 0 2.1rem;
  }

  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }

  .cta-button {
    display: inline-block;
    padding: 0.8rem 2rem;
    background-color: var(--color-nav-bg);
    color: white;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: background-color 0.15s;
    border: 2px solid var(--color-nav-bg);
  }

  .cta-button:hover {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>

<script>
  // ─── Rain Config (all tunables) ───
  const RC = {
    fontSize: 9,
    dropSpeedMin: 0.26,
    dropSpeedRange: 0.69,
    trailSteps: 40,
    trailBaseAlpha: 0.35,
    trailDecay: 0.058,
    leadAlpha: 0.66,
    effectR: 0,
    effectG: 95,
    effectB: 184,
    umbrellaCore: 0.65,
    umbrellaThreshold: 0.65,
    swayAmplitude: 1.75,
    swayFrequency: 0.145,
    respawnMin: 64,
    respawnRange: 42,
    rippleMinRadius: 20,
    rippleRadiusRange: 30,
    rippleBaseOpacity: 0.6,
    rippleOpacityRange: 0.2,
    rippleSpeed: 0.52,
    splashDropletMin: 14,
    splashDropletRange: 7,
    splashVx: 2.2,
    splashVy: 2.2,
    splashVyBase: 2.2,
    splashChance: 1,
    waterlineOffset: 20,
    columnDensity: 1.35,
  };
  (window as any).__RC = RC;

  const canvas = document.getElementById('matrix-rain') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const rippleCanvas = document.getElementById('ripple-canvas') as HTMLCanvasElement;
  const rctx = rippleCanvas.getContext('2d')!;
  const titleSplashCanvas = document.getElementById('title-splash') as HTMLCanvasElement;
  const tsctx = titleSplashCanvas.getContext('2d')!;
  const heroOutlineImg = document.getElementById('hero-outline') as HTMLImageElement | null;
  const heroTitle = document.querySelector('.hero h1') as HTMLElement | null;
  const heroSubtitle = document.querySelector('.hero-subtitle') as HTMLElement | null;
  const rootStyles = getComputedStyle(document.documentElement);
  const pageBg = rootStyles.getPropertyValue('--color-bg').trim() || '#f4f5f7';

  const rippleHeight = 60;

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    rippleCanvas.width = window.innerWidth;
    rippleCanvas.height = rippleHeight;
    titleSplashCanvas.width = window.innerWidth;
    titleSplashCanvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  const chars = 'アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン0123456789ABCDEF';
  const charArr = chars.split('');
  let columns = Math.floor(canvas.width / RC.fontSize);
  let drops: number[] = [];
  let dropSpeeds: number[] = [];

  function initDrops() {
    columns = Math.floor((canvas.width / RC.fontSize) * RC.columnDensity);
    drops = [];
    dropSpeeds = [];
    for (let i = 0; i < columns; i++) {
      drops[i] = Math.random() * -140;
      dropSpeeds[i] = RC.dropSpeedMin + Math.random() * RC.dropSpeedRange;
    }
  }
  initDrops();
  window.addEventListener('resize', initDrops);

  interface Ripple {
    x: number;
    radius: number;
    maxRadius: number;
    opacity: number;
  }

  interface SplashDroplet {
    vx: number;
    vy: number;
    size: number;
    xBias: number;
  }

  interface TitleSplash {
    x: number;
    y: number;
    age: number;
    life: number;
    opacity: number;
    droplets: SplashDroplet[];
  }

  let ripples: Ripple[] = [];
  let titleSplashes: TitleSplash[] = [];

  function spawnRipple(x: number) {
    ripples.push({
      x,
      radius: 1,
      maxRadius: RC.rippleMinRadius + Math.random() * RC.rippleRadiusRange,
      opacity: RC.rippleBaseOpacity + Math.random() * RC.rippleOpacityRange,
    });
  }

  function spawnTitleSplash(x: number, y: number) {
    const dropletCount = RC.splashDropletMin + Math.floor(Math.random() * RC.splashDropletRange);
    const droplets: SplashDroplet[] = [];
    for (let i = 0; i < dropletCount; i++) {
      droplets.push({
        vx: (Math.random() - 0.5) * RC.splashVx,
        vy: -RC.splashVyBase - Math.random() * RC.splashVy,
        size: 0.8 + Math.random() * 1.5,
        xBias: (Math.random() - 0.5) * 6,
      });
    }

    titleSplashes.push({
      x,
      y,
      age: 0,
      life: 14 + Math.random() * 8,
      opacity: 0.5 + Math.random() * 0.25,
      droplets,
    });
  }

  let lastTime = 0;
  const baseFrameMs = 1000 / 60;

  function getUmbrellaStrength(
    x: number,
    y: number,
    zone: { cx: number; cy: number; rx: number; ry: number }
  ) {
    const nx = (x - zone.cx) / zone.rx;
    const ny = (y - zone.cy) / zone.ry;
    const dist = Math.sqrt(nx * nx + ny * ny);
    if (dist <= RC.umbrellaCore) return 1;
    if (dist >= 1) return 0;
    const t = (1 - dist) / (1 - RC.umbrellaCore);
    return t * t * (3 - 2 * t);
  }

  function dilateMask(mask: Uint8Array, width: number, height: number) {
    const out = new Uint8Array(mask.length);
    for (let y = 0; y < height; y++) {
      for (let x = 0; x < width; x++) {
        let on = 0;
        for (let yy = -1; yy <= 1 && !on; yy++) {
          const ny = y + yy;
          if (ny < 0 || ny >= height) continue;
          for (let xx = -1; xx <= 1; xx++) {
            const nx = x + xx;
            if (nx < 0 || nx >= width) continue;
            if (mask[ny * width + nx]) {
              on = 1;
              break;
            }
          }
        }
        out[y * width + x] = on;
      }
    }
    return out;
  }

  function erodeMask(mask: Uint8Array, width: number, height: number) {
    const out = new Uint8Array(mask.length);
    for (let y = 0; y < height; y++) {
      for (let x = 0; x < width; x++) {
        let keep = 1;
        for (let yy = -1; yy <= 1 && keep; yy++) {
          const ny = y + yy;
          if (ny < 0 || ny >= height) {
            keep = 0;
            break;
          }
          for (let xx = -1; xx <= 1; xx++) {
            const nx = x + xx;
            if (nx < 0 || nx >= width || !mask[ny * width + nx]) {
              keep = 0;
              break;
            }
          }
        }
        out[y * width + x] = keep;
      }
    }
    return out;
  }

  function keepLargestBlob(mask: Uint8Array, width: number, height: number) {
    const visited = new Uint8Array(mask.length);
    const best = new Uint8Array(mask.length);
    let bestCount = 0;

    for (let i = 0; i < mask.length; i++) {
      if (!mask[i] || visited[i]) continue;
      const queue: number[] = [i];
      const blob: number[] = [];
      visited[i] = 1;

      for (let q = 0; q < queue.length; q++) {
        const idx = queue[q];
        blob.push(idx);
        const x = idx % width;
        const y = (idx - x) / width;
        const neighbors = [
          [x - 1, y], [x + 1, y], [x, y - 1], [x, y + 1],
          [x - 1, y - 1], [x + 1, y - 1], [x - 1, y + 1], [x + 1, y + 1],
        ];
        for (let n = 0; n < neighbors.length; n++) {
          const nx = neighbors[n][0];
          const ny = neighbors[n][1];
          if (nx < 0 || nx >= width || ny < 0 || ny >= height) continue;
          const ni = ny * width + nx;
          if (mask[ni] && !visited[ni]) {
            visited[ni] = 1;
            queue.push(ni);
          }
        }
      }

      if (blob.length > bestCount) {
        best.fill(0);
        for (let b = 0; b < blob.length; b++) {
          best[blob[b]] = 1;
        }
        bestCount = blob.length;
      }
    }

    return best;
  }

  function keepSeedBlob(mask: Uint8Array, width: number, height: number, seedX: number, seedY: number) {
    const out = new Uint8Array(mask.length);
    const visited = new Uint8Array(mask.length);

    const clampX = Math.max(0, Math.min(width - 1, seedX));
    const clampY = Math.max(0, Math.min(height - 1, seedY));
    let seedIdx = clampY * width + clampX;

    if (!mask[seedIdx]) {
      let found = -1;
      for (let r = 1; r < Math.max(width, height) && found < 0; r++) {
        const x0 = Math.max(0, clampX - r);
        const x1 = Math.min(width - 1, clampX + r);
        const y0 = Math.max(0, clampY - r);
        const y1 = Math.min(height - 1, clampY + r);
        for (let y = y0; y <= y1 && found < 0; y++) {
          for (let x = x0; x <= x1; x++) {
            const idx = y * width + x;
            if (mask[idx]) {
              found = idx;
              break;
            }
          }
        }
      }
      if (found < 0) return out;
      seedIdx = found;
    }

    const queue: number[] = [seedIdx];
    visited[seedIdx] = 1;
    out[seedIdx] = 1;

    for (let q = 0; q < queue.length; q++) {
      const idx = queue[q];
      const x = idx % width;
      const y = (idx - x) / width;
      const neighbors = [
        [x - 1, y], [x + 1, y], [x, y - 1], [x, y + 1],
        [x - 1, y - 1], [x + 1, y - 1], [x - 1, y + 1], [x + 1, y + 1],
      ];
      for (let n = 0; n < neighbors.length; n++) {
        const nx = neighbors[n][0];
        const ny = neighbors[n][1];
        if (nx < 0 || nx >= width || ny < 0 || ny >= height) continue;
        const ni = ny * width + nx;
        if (mask[ni] && !visited[ni]) {
          visited[ni] = 1;
          out[ni] = 1;
          queue.push(ni);
        }
      }
    }

    return out;
  }

  function countMask(mask: Uint8Array) {
    let count = 0;
    for (let i = 0; i < mask.length; i++) {
      if (mask[i]) count++;
    }
    return count;
  }

  function detectEdge(mask: Uint8Array, width: number, height: number) {
    const edge = new Uint8Array(mask.length);
    for (let y = 0; y < height; y++) {
      for (let x = 0; x < width; x++) {
        const idx = y * width + x;
        if (!mask[idx]) continue;
        let border = 0;
        for (let yy = -1; yy <= 1 && !border; yy++) {
          const ny = y + yy;
          if (ny < 0 || ny >= height) {
            border = 1;
            break;
          }
          for (let xx = -1; xx <= 1; xx++) {
            const nx = x + xx;
            if (nx < 0 || nx >= width || !mask[ny * width + nx]) {
              border = 1;
              break;
            }
          }
        }
        if (border) edge[idx] = 1;
      }
    }
    return edge;
  }

  function initHeroImage() {
    if (!heroOutlineImg) return;
    const sourcePath = heroOutlineImg.getAttribute('src') || '/me.jpg';
    const candidates = Array.from(new Set([sourcePath, '/me.jpg', 'me.jpg', './me.jpg']));
    const tryLoadAt = (idx: number) => {
      if (idx >= candidates.length) {
        heroOutlineImg.style.display = 'none';
        return;
      }
      heroOutlineImg.onerror = () => tryLoadAt(idx + 1);
      heroOutlineImg.src = candidates[idx];
    };
    tryLoadAt(0);
  }

  function draw(timestamp: number) {
    requestAnimationFrame(draw);

    const deltaMs = lastTime ? Math.min(34, timestamp - lastTime) : 16.67;
    const timeScale = deltaMs / baseFrameMs;
    lastTime = timestamp;

    const effectRgb = `${RC.effectR}, ${RC.effectG}, ${RC.effectB}`;
    const waterline = canvas.height - RC.waterlineOffset;

    ctx.fillStyle = pageBg;
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    ctx.fillStyle = pageBg;
    ctx.fillRect(0, waterline, canvas.width, canvas.height - waterline);

    const titleRect = heroTitle?.getBoundingClientRect();
    const subtitleRect = heroSubtitle?.getBoundingClientRect();
    let umbrellaZone: { cx: number; cy: number; rx: number; ry: number } | null = null;
    if (titleRect && subtitleRect) {
      const left = Math.min(titleRect.left, subtitleRect.left) - 26;
      const right = Math.max(titleRect.right, subtitleRect.right) + 26;
      const top = titleRect.top - 18;
      const bottom = subtitleRect.bottom + 26;
      umbrellaZone = {
        cx: (left + right) * 0.5,
        cy: (top + bottom) * 0.5,
        rx: (right - left) * 0.5,
        ry: (bottom - top) * 0.5,
      };
    }
    ctx.font = `${RC.fontSize}px "Baloo 2", sans-serif`;

    const colWidth = RC.fontSize / RC.columnDensity;
    for (let i = 0; i < drops.length; i++) {
      if (drops[i] < 0) {
        drops[i] += dropSpeeds[i] * timeScale;
        continue;
      }

      const char = charArr[Math.floor(Math.random() * charArr.length)];
      const x = i * colWidth;
      const y = drops[i] * RC.fontSize;
      const impactX = x + RC.fontSize * 0.5;

      if (y >= waterline) {
        spawnRipple(Math.min(impactX, canvas.width));
        drops[i] = Math.random() * -(RC.respawnMin + Math.random() * RC.respawnRange);
        continue;
      }

      if (
        titleRect &&
        impactX >= titleRect.left &&
        impactX <= titleRect.right &&
        y >= titleRect.top &&
        y <= titleRect.bottom &&
        Math.random() < RC.splashChance
      ) {
        spawnTitleSplash(impactX, y);
      }

      const umbrellaStrength = umbrellaZone ? getUmbrellaStrength(impactX, y, umbrellaZone) : 0;
      if (umbrellaStrength > RC.umbrellaThreshold) {
        drops[i] = Math.random() * -(RC.respawnMin + Math.random() * RC.respawnRange);
        continue;
      }

      const leadAlpha = RC.leadAlpha * (1 - umbrellaStrength * 0.9);
      const drawX = x + Math.sin((drops[i] + i * 0.37) * RC.swayFrequency) * RC.swayAmplitude;
      ctx.fillStyle = `rgba(${effectRgb}, ${leadAlpha})`;
      ctx.fillText(char, drawX, y);

      if (drops[i] > 1) {
        const baseTrailAlpha = RC.trailBaseAlpha * (1 - umbrellaStrength * 0.85);
        for (let t = 0; t < RC.trailSteps; t++) {
          const step = t + 1;
          const trailChar = charArr[Math.floor(Math.random() * charArr.length)];
          const trailAlpha = baseTrailAlpha * (1 - t * RC.trailDecay);
          ctx.fillStyle = `rgba(${effectRgb}, ${trailAlpha})`;
          ctx.fillText(trailChar, drawX, y - RC.fontSize * step);
        }
      }

      drops[i] += dropSpeeds[i] * timeScale;
    }

    // --- Draw title splashes ---
    tsctx.clearRect(0, 0, titleSplashCanvas.width, titleSplashCanvas.height);
    const splashEffectRgb = `${RC.effectR}, ${RC.effectG}, ${RC.effectB}`;
    for (let i = titleSplashes.length - 1; i >= 0; i--) {
      const s = titleSplashes[i];
      const progress = s.age / s.life;
      const currentOpacity = s.opacity * (1 - progress);
      const gravity = 0.18 * s.age;

      tsctx.beginPath();
      tsctx.arc(s.x, s.y, 1.2 + progress * 1.8, 0, Math.PI * 2);
      tsctx.fillStyle = `rgba(${splashEffectRgb}, ${currentOpacity})`;
      tsctx.fill();

      for (let j = 0; j < s.droplets.length; j++) {
        const d = s.droplets[j];
        const px = s.x + d.xBias + d.vx * s.age;
        const py = s.y + d.vy * s.age + gravity;
        tsctx.beginPath();
        tsctx.arc(px, py, d.size * (1 - progress * 0.35), 0, Math.PI * 2);
        tsctx.fillStyle = `rgba(${splashEffectRgb}, ${currentOpacity * 0.95})`;
        tsctx.fill();
      }

      s.age += timeScale;

      if (s.age >= s.life) {
        titleSplashes.splice(i, 1);
      }
    }

    // --- Draw ripples ---
    rctx.clearRect(0, 0, rippleCanvas.width, rippleCanvas.height);
    const rippleEffectRgb = `${RC.effectR}, ${RC.effectG}, ${RC.effectB}`;

    for (let i = ripples.length - 1; i >= 0; i--) {
      const r = ripples[i];
      const progress = r.radius / r.maxRadius;
      const currentOpacity = r.opacity * (1 - progress);

      // Outer ring
      rctx.beginPath();
      rctx.ellipse(r.x, rippleCanvas.height - 5, r.radius, r.radius * 0.35, 0, 0, Math.PI * 2);
      rctx.strokeStyle = `rgba(${rippleEffectRgb}, ${currentOpacity})`;
      rctx.lineWidth = 2;
      rctx.stroke();

      // Inner ring
      if (r.radius > 5) {
        rctx.beginPath();
        rctx.ellipse(r.x, rippleCanvas.height - 5, r.radius * 0.5, r.radius * 0.18, 0, 0, Math.PI * 2);
        rctx.strokeStyle = `rgba(${rippleEffectRgb}, ${currentOpacity * 0.7})`;
        rctx.lineWidth = 1.5;
        rctx.stroke();
      }

      r.radius += RC.rippleSpeed * timeScale;

      if (r.radius >= r.maxRadius) {
        ripples.splice(i, 1);
      }
    }
  }

  // Clear canvas to white first
  ctx.fillStyle = pageBg;
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  initHeroImage();
  requestAnimationFrame(draw);

  // ─── Rain Control Panel ───
  const toggleBtn = document.getElementById('rain-ctrl-toggle') as HTMLButtonElement | null;
  const panel = document.getElementById('rain-controls-panel') as HTMLDivElement | null;

  const showControls = new URLSearchParams(window.location.search).has('rain-controls');
  if (toggleBtn && panel && showControls) {
    toggleBtn.style.display = 'inline-block';
    let panelOpen = false;

    // Panel styles
    Object.assign(panel.style, {
      position: 'fixed',
      top: '48px',
      right: '12px',
      width: '340px',
      maxHeight: 'calc(100vh - 60px)',
      overflowY: 'auto',
      background: 'rgba(255,255,255,0.97)',
      border: '2px solid #005fb8',
      borderRadius: '8px',
      padding: '14px 16px',
      zIndex: '9999',
      fontFamily: 'var(--font-sans)',
      fontSize: '12px',
      boxShadow: '0 4px 24px rgba(0,0,0,0.13)',
    });

    type SliderDef = {
      key: keyof typeof RC;
      label: string;
      min: number;
      max: number;
      step: number;
      reinit?: boolean;
    };

    const sliders: SliderDef[] = [
      { key: 'fontSize', label: 'Font Size', min: 6, max: 30, step: 1, reinit: true },
      { key: 'columnDensity', label: 'Column Density', min: 0.2, max: 3, step: 0.05, reinit: true },
      { key: 'dropSpeedMin', label: 'Drop Speed Min', min: 0.05, max: 2, step: 0.01, reinit: true },
      { key: 'dropSpeedRange', label: 'Drop Speed Range', min: 0, max: 1, step: 0.01, reinit: true },
      { key: 'trailSteps', label: 'Trail Length', min: 0, max: 40, step: 1 },
      { key: 'trailBaseAlpha', label: 'Trail Alpha', min: 0, max: 1, step: 0.01 },
      { key: 'trailDecay', label: 'Trail Decay', min: 0.001, max: 0.2, step: 0.001 },
      { key: 'leadAlpha', label: 'Lead Alpha', min: 0, max: 1, step: 0.01 },
      { key: 'effectR', label: 'Color R', min: 0, max: 255, step: 1 },
      { key: 'effectG', label: 'Color G', min: 0, max: 255, step: 1 },
      { key: 'effectB', label: 'Color B', min: 0, max: 255, step: 1 },
      { key: 'swayAmplitude', label: 'Sway Amplitude', min: 0, max: 5, step: 0.05 },
      { key: 'swayFrequency', label: 'Sway Frequency', min: 0, max: 1, step: 0.005 },
      { key: 'umbrellaCore', label: 'Umbrella Core', min: 0, max: 1, step: 0.01 },
      { key: 'umbrellaThreshold', label: 'Umbrella Threshold', min: 0, max: 1, step: 0.01 },
      { key: 'respawnMin', label: 'Respawn Min Delay', min: 0, max: 200, step: 1 },
      { key: 'respawnRange', label: 'Respawn Delay Range', min: 0, max: 200, step: 1 },
      { key: 'waterlineOffset', label: 'Waterline Offset', min: 0, max: 200, step: 1 },
      { key: 'rippleMinRadius', label: 'Ripple Min Radius', min: 0, max: 80, step: 1 },
      { key: 'rippleRadiusRange', label: 'Ripple Radius Range', min: 0, max: 80, step: 1 },
      { key: 'rippleBaseOpacity', label: 'Ripple Opacity', min: 0, max: 1, step: 0.01 },
      { key: 'rippleSpeed', label: 'Ripple Speed', min: 0.05, max: 3, step: 0.01 },
      { key: 'splashDropletMin', label: 'Splash Droplets Min', min: 0, max: 20, step: 1 },
      { key: 'splashDropletRange', label: 'Splash Droplets Range', min: 0, max: 15, step: 1 },
      { key: 'splashVx', label: 'Splash Vx', min: 0, max: 8, step: 0.1 },
      { key: 'splashVyBase', label: 'Splash Vy Base', min: 0, max: 8, step: 0.1 },
      { key: 'splashVy', label: 'Splash Vy Range', min: 0, max: 8, step: 0.1 },
      { key: 'splashChance', label: 'Splash Chance', min: 0, max: 1, step: 0.01 },
    ];

    // Color swatch
    const swatchRow = document.createElement('div');
    swatchRow.style.cssText = 'display:flex;align-items:center;gap:8px;margin-bottom:10px;';
    const swatchLabel = document.createElement('span');
    swatchLabel.textContent = 'Preview:';
    swatchLabel.style.fontWeight = '600';
    const swatch = document.createElement('div');
    swatch.id = 'rc-swatch';
    swatch.style.cssText = `width:32px;height:18px;border-radius:3px;border:1px solid #ccc;background:rgb(${RC.effectR},${RC.effectG},${RC.effectB});`;
    swatchRow.appendChild(swatchLabel);
    swatchRow.appendChild(swatch);

    // Title
    const title = document.createElement('div');
    title.style.cssText = 'font-weight:700;font-size:14px;margin-bottom:8px;color:#005fb8;display:flex;justify-content:space-between;align-items:center;';
    title.innerHTML = '<span>Rain Controls</span>';

    // Export button
    const exportBtn = document.createElement('button');
    exportBtn.textContent = 'Copy Config';
    exportBtn.style.cssText = 'font-size:11px;padding:3px 8px;cursor:pointer;border:1px solid #005fb8;background:#eef4fb;color:#005fb8;border-radius:3px;font-family:inherit;';
    exportBtn.addEventListener('click', () => {
      const json = JSON.stringify(RC, null, 2);
      navigator.clipboard.writeText(json).then(() => {
        exportBtn.textContent = 'Copied!';
        setTimeout(() => exportBtn.textContent = 'Copy Config', 1500);
      });
    });
    title.appendChild(exportBtn);

    panel.appendChild(title);
    panel.appendChild(swatchRow);

    // Group headers
    const groups: Record<string, string[]> = {
      'Drops': ['fontSize', 'columnDensity', 'dropSpeedMin', 'dropSpeedRange'],
      'Trail': ['trailSteps', 'trailBaseAlpha', 'trailDecay', 'leadAlpha'],
      'Color': ['effectR', 'effectG', 'effectB'],
      'Sway': ['swayAmplitude', 'swayFrequency'],
      'Umbrella': ['umbrellaCore', 'umbrellaThreshold'],
      'Respawn': ['respawnMin', 'respawnRange', 'waterlineOffset'],
      'Ripples': ['rippleMinRadius', 'rippleRadiusRange', 'rippleBaseOpacity', 'rippleSpeed'],
      'Splashes': ['splashDropletMin', 'splashDropletRange', 'splashVx', 'splashVyBase', 'splashVy', 'splashChance'],
    };

    function updateSwatch() {
      const s = document.getElementById('rc-swatch');
      if (s) s.style.background = `rgb(${RC.effectR},${RC.effectG},${RC.effectB})`;
    }

    for (const [groupName, keys] of Object.entries(groups)) {
      const header = document.createElement('div');
      header.style.cssText = 'font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#666;margin:10px 0 4px;border-bottom:1px solid #e0e0e0;padding-bottom:2px;';
      header.textContent = groupName;
      panel.appendChild(header);

      for (const key of keys) {
        const def = sliders.find(s => s.key === key);
        if (!def) continue;

        const row = document.createElement('div');
        row.style.cssText = 'display:flex;align-items:center;gap:6px;margin:3px 0;';

        const label = document.createElement('label');
        label.textContent = def.label;
        label.style.cssText = 'flex:0 0 130px;font-size:11px;color:#333;';

        const input = document.createElement('input');
        input.type = 'range';
        input.min = String(def.min);
        input.max = String(def.max);
        input.step = String(def.step);
        input.value = String(RC[def.key]);
        input.style.cssText = 'flex:1;height:16px;accent-color:#005fb8;';

        const valSpan = document.createElement('span');
        valSpan.textContent = String(RC[def.key]);
        valSpan.style.cssText = 'flex:0 0 42px;text-align:right;font-size:11px;font-family:monospace;color:#005fb8;cursor:pointer;';
        valSpan.title = 'Click to edit';

        // Click value to type a number directly
        valSpan.addEventListener('click', () => {
          const numInput = document.createElement('input');
          numInput.type = 'number';
          numInput.min = String(def.min);
          numInput.max = String(def.max);
          numInput.step = String(def.step);
          numInput.value = String(RC[def.key]);
          numInput.style.cssText = 'width:50px;font-size:11px;font-family:monospace;border:1px solid #005fb8;border-radius:2px;padding:1px 3px;';
          valSpan.replaceWith(numInput);
          numInput.focus();
          numInput.select();
          const commit = () => {
            const v = parseFloat(numInput.value);
            if (!isNaN(v)) {
              (RC as any)[def.key] = Math.max(def.min, Math.min(def.max, v));
              input.value = String(RC[def.key]);
            }
            valSpan.textContent = String(RC[def.key]);
            numInput.replaceWith(valSpan);
            if (def.reinit) initDrops();
            updateSwatch();
          };
          numInput.addEventListener('blur', commit);
          numInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') commit(); });
        });

        input.addEventListener('input', () => {
          (RC as any)[def.key] = parseFloat(input.value);
          valSpan.textContent = input.value;
          if (def.reinit) initDrops();
          updateSwatch();
        });

        row.appendChild(label);
        row.appendChild(input);
        row.appendChild(valSpan);
        panel.appendChild(row);
      }
    }

    // Reset button
    const resetRow = document.createElement('div');
    resetRow.style.cssText = 'margin-top:12px;text-align:center;';
    const resetBtn = document.createElement('button');
    resetBtn.textContent = 'Reset Defaults';
    resetBtn.style.cssText = 'font-size:11px;padding:4px 14px;cursor:pointer;border:1px solid #c00;background:#fff0f0;color:#c00;border-radius:3px;font-family:inherit;';
    resetBtn.addEventListener('click', () => {
      const defaults = {
        fontSize: 9, dropSpeedMin: 0.26, dropSpeedRange: 0.69,
        trailSteps: 40, trailBaseAlpha: 0.35, trailDecay: 0.058,
        leadAlpha: 0.66, effectR: 0, effectG: 95, effectB: 184,
        umbrellaCore: 0.65, umbrellaThreshold: 0.65,
        swayAmplitude: 1.75, swayFrequency: 0.145,
        respawnMin: 64, respawnRange: 42,
        rippleMinRadius: 20, rippleRadiusRange: 30,
        rippleBaseOpacity: 0.6, rippleOpacityRange: 0.2,
        rippleSpeed: 0.52,
        splashDropletMin: 14, splashDropletRange: 7,
        splashVx: 2.2, splashVy: 2.2, splashVyBase: 2.2,
        splashChance: 1, waterlineOffset: 20, columnDensity: 1.35,
      };
      Object.assign(RC, defaults);
      // Refresh all sliders
      panel.querySelectorAll('input[type=range]').forEach((inp) => {
        const rangeInp = inp as HTMLInputElement;
        const def = sliders.find(s => s.label === rangeInp.closest('div')?.querySelector('label')?.textContent);
        if (def) {
          rangeInp.value = String(RC[def.key]);
          const valEl = rangeInp.nextElementSibling as HTMLElement;
          if (valEl) valEl.textContent = String(RC[def.key]);
        }
      });
      initDrops();
      updateSwatch();
    });
    resetRow.appendChild(resetBtn);
    panel.appendChild(resetRow);

    toggleBtn.addEventListener('click', () => {
      panelOpen = !panelOpen;
      panel.style.display = panelOpen ? 'block' : 'none';
      toggleBtn.style.borderColor = panelOpen ? '#c00' : 'var(--color-accent)';
      toggleBtn.style.color = panelOpen ? '#c00' : 'var(--color-accent)';
      toggleBtn.innerHTML = panelOpen ? '✕ Rain' : '⚙ Rain';
    });
  }
</script>
